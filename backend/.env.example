# ── App Settings ──
DEBUG=true
HOST=0.0.0.0
PORT=8000

# ── Database (SQLite default, switch to PostgreSQL for production) ──
# DATABASE_URL=sqlite:///./data/facerecog.db
# DATABASE_URL=postgresql://user:password@localhost:5432/facerecog

# ── Face Recognition ──
SIMILARITY_THRESHOLD=0.45
FACE_DETECTION_CONFIDENCE=0.5

# ── Anti-Spoofing ──
ANTI_SPOOF_ENABLED=true
LBP_VARIANCE_THRESHOLD=30.0
LAPLACIAN_THRESHOLD=50.0

# ── Security ──
API_KEY=
CORS_ORIGINS=["http://localhost:5173","http://localhost:3000"]
